    <bpmn2:userTask id="_C6B3F43A-382F-4EA2-8939-27B068EBDEB0" name="Order Preparation">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Order Preparation]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[if ("PARTIAL_STOCK".equals(kcontext.getVariable("stockLevel"))) {
    kcontext.setVariable("currentState","PARTIAL_INVENTORY_READY_FOR_ASSEMBLY");
} else {
    kcontext.setVariable("currentState","READY_FOR_ASSEMBLY");
}
System.out.println(kcontext.getVariable("currentState"));]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[if (Boolean.TRUE.equals(kcontext.getVariable("assemblyCompleted"))) {
    kcontext.setVariable("currentState","READY_FOR_PICKUP");
}
System.out.println(kcontext.getVariable("currentState"));]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>
