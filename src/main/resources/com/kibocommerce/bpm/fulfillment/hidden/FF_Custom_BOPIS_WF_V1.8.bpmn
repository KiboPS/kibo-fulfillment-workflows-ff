    <bpmn2:userTask id="_6435A331-0795-4719-989B-F9FB69570FC5" name="Customer Pickup">
      <bpmn2:documentation id="_ZkqX8ngbEfCIQvmi1OmrLw"><![CDATA[Customer Pickup User Task]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Customer Pickup]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[kcontext.setVariable("currentState","READY_FOR_PICKUP");]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[if (!customerAccepted) {
kcontext.setVariable("currentState","CANCELED");
} else {
kcontext.setVariable("currentState","COMPLETED");
}
System.out.println(kcontext.getVariable("currentState"));]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>
