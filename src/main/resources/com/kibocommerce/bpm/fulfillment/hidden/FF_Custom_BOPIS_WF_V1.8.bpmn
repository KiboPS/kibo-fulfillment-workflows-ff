    <bpmn2:sequenceFlow id="_C01CE53E-95C7-4E50-9F9A-8AA3B3B643F6" name="yes" sourceRef="_B9216ACC-6D35-4F2D-A065-06941B24E09A" targetRef="_EF577B24-F9CB-40BB-B01A-F90D1A7527A9">
