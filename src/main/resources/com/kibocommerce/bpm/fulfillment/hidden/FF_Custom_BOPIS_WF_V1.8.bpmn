      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" id="_-M2qY7r0EfCEt8L_pcLEzw" language="http://www.java.com/java"><![CDATA[Object forceFulfill1 = kcontext.getVariable("forceFulfill");

org.slf4j.Logger logger = org.slf4j.LoggerFactory.getLogger("jbpm-workflow-logs");
org.kie.api.runtime.process.ProcessInstance pi = kcontext.getProcessInstance();
org.kie.api.definition.process.Process process = pi.getProcess();

String processId = process.getId();
String version = process.getVersion();
long instanceId = pi.getId();
String nodeName = kcontext.getNodeInstance().getNodeName();

logger.info(
  "BPMN LOG: [Process: {}, Version: {}, Instance: {}] is at node [{}].",
  processId,
  version,
  instanceId,
  nodeName
);
