      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" id="_8V7U-rAzEfCd35Bv_slBeA" language="http://www.java.com/java"><![CDATA[Object isAgeRestrictedVar = kcontext.getVariable("isAgeRestricted");

// 1. Get a logger instance
org.slf4j.Logger logger = org.slf4j.LoggerFactory.getLogger("jbpm-workflow-logs");

// 2. Get all your context info from kcontext
String processId = kcontext.getProcessInstance().getProcessId();
String version = kcontext.getProcessInstance().getProcessVersion();
long instanceId = kcontext.getProcessInstance().getId();
String nodeName = kcontext.getNodeInstance().getNodeName();
Object ageVar = kcontext.getVariable("isAgeRestricted");

// 3. Log the information
logger.info(
  "BPMN LOG: [Process: {}, Version: {}, Instance: {}] is at node [{}]. Variable 'isAgeRestricted' = {}",
  processId,
  version,
  instanceId,
  nodeName,
  ageVar
);

return !Boolean.TRUE.equals(Boolean.valueOf(isAgeRestrictedVar.toString()));]]></bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
