    <bpmn2:userTask id="_6435A331-0795-4719-989B-F9FB69570FC5" name="Prepare for Shipment">
      <bpmn2:documentation id="_HW-j4gjUEfCl3YWJzWw0eA"><![CDATA[Prepare for Shipment User Task]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Prepare for Shipment]]></drools:metaValue>
        </drools:metaData>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[if (Boolean.TRUE.equals(back)) {
kcontext.setVariable("back", false);
kcontext.setVariable("currentState","INVENTORY_AVAILABLE");
kcontext.getKieRuntime().signalEvent("back", null, kcontext.getProcessInstance().getId());
} else if (Boolean.TRUE.equals(canceled)) {
    kcontext.setVariable("currentState","CANCELED");
} else {
    kcontext.setVariable("currentState","COMPLETED");
}]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>
