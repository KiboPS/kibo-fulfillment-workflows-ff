    <bpmn2:userTask id="_B8B9C3CA-5BC8-4476-BA22-1D4324FAC12B" name="Validate Items In Stock">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Validate Items In Stock]]></drools:metaValue>
        </drools:metaData>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[if ("IN_STOCK".equals(stockLevel)) {
kcontext.setVariable("currentState","INVENTORY_AVAILABLE");
} else if ("PARTIAL_STOCK".equals(stockLevel)) {
kcontext.setVariable("currentState","PARTIAL_INVENTORY_NOPE");
} else {
kcontext.setVariable("currentState","INVENTORY_NOPE");
}
