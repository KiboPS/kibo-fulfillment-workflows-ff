    <bpmn2:userTask id="_7BA67831-15C6-42D1-8556-3535D7DCBB88" name="Print Packing Slip">
      <bpmn2:documentation id="_UXGt1XgbEfCIQvmi1OmrLw"><![CDATA[Print Packing Slip User Task]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
